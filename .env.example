# PropIntelli AI — configuration template.
# Copy to `.env` and adjust. No secrets are committed; `.env` is git-ignored.
# Every value below has a safe default in src/propintelli/config.py, so the
# pipeline runs fully offline with an empty .env.

# ---------------------------------------------------------------------------
# Storage / data layout
# ---------------------------------------------------------------------------
# Root directory for the medallion layers (Bronze raw store, Silver SQLite DB,
# Gold DuckDB + file exports). Created on first run.
PROPINTELLI_DATA_DIR=./data

# ---------------------------------------------------------------------------
# Extraction — Layer B (LLM). Layer A (deterministic) is always on.
# Provider: none | ollama | openai | azure_openai
#   none         -> offline, deterministic only (default; CI + reproducible demo)
#   ollama       -> local LLM, free (requires `ollama serve`)
#   openai       -> OpenAI API (requires OPENAI_API_KEY)
#   azure_openai -> Azure OpenAI (requires AZURE_OPENAI_* below)
# ---------------------------------------------------------------------------
PROPINTELLI_LLM_PROVIDER=none

# Prompt variant used by the LLM layer: v1_direct | v2_schema | v3_reasoning
PROPINTELLI_LLM_PROMPT_VARIANT=v2_schema

# Ollama
PROPINTELLI_OLLAMA_BASE_URL=http://localhost:11434
PROPINTELLI_OLLAMA_MODEL=llama3.1

# OpenAI
OPENAI_API_KEY=
PROPINTELLI_OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
PROPINTELLI_AZURE_OPENAI_API_VERSION=2024-06-01

# LLM call budget. The 60s default suits hosted APIs (OpenAI/Azure). A LOCAL
# model (Ollama) generating the full schema can take far longer on CPU-bound
# hardware — set this to 300+ for local backends, or the call will time out and
# the pipeline will downgrade to the deterministic layer.
PROPINTELLI_LLM_TIMEOUT_SECONDS=60
PROPINTELLI_LLM_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# Preprocessing / OCR (optional). OCR is only attempted when enabled AND the
# Tesseract binary is available; otherwise the digital-text path is used.
# ---------------------------------------------------------------------------
PROPINTELLI_OCR_ENABLED=false
PROPINTELLI_OCR_LANGUAGE=deu
# Page is treated as "scanned" when its embedded-text density falls below this.
PROPINTELLI_SCANNED_TEXT_THRESHOLD=50

# ---------------------------------------------------------------------------
# Confidence-driven human-in-the-loop routing thresholds.
# >= auto_approve            -> auto_approved
# review_floor .. auto_approve -> needs_review
# < review_floor             -> manual_required
# ---------------------------------------------------------------------------
PROPINTELLI_CONFIDENCE_AUTO_APPROVE=0.85
PROPINTELLI_CONFIDENCE_REVIEW_FLOOR=0.60

# ---------------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING | ERROR. Set json=true for structured logs.
# ---------------------------------------------------------------------------
PROPINTELLI_LOG_LEVEL=INFO
PROPINTELLI_LOG_JSON=false
