# Python image for the extraction worker and CLI.
# Built from the repository root: `docker build -f docker/Dockerfile.python .`
FROM python:3.13-slim AS base

# Tesseract (German) + poppler enable the optional OCR path inside the container.
RUN apt-get update \
    && apt-get install -y --no-install-recommends tesseract-ocr tesseract-ocr-deu poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast, reproducible dependency resolution.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app
ENV UV_PROJECT_ENVIRONMENT=/usr/local \
    UV_COMPILE_BYTECODE=1 \
    PROPINTELLI_DATA_DIR=/data

# Resolve dependencies first (cached unless the lockfile/pyproject change).
COPY pyproject.toml uv.lock README.md ./
RUN uv sync --no-dev --extra ocr --extra llm --extra ui --no-install-project

# Install the project itself.
COPY src ./src
RUN uv sync --no-dev --extra ocr --extra llm --extra ui

VOLUME ["/data"]
ENTRYPOINT ["propintelli"]
CMD ["info"]
